# ============================================
# 律植 - 部署环境变量模板（无密钥）
# 用法：cp deploy/.env.template deploy/.env
# ============================================
COMPOSE_PROJECT_NAME=lvzhi
NODE_ENV=production
APP_NAME=律植
APP_URL=https://www.lvxzhi.com
WEB_URL=https://www.lvxzhi.com,https://lvxzhi.com
API_URL=https://www.lvxzhi.com/api
NEXT_PUBLIC_API_URL=https://www.lvxzhi.com/api

# 镜像标记（部署脚本会覆盖为 commit sha）
IMAGE_TAG=latest

# Nginx 对外端口（生产建议固定 80/443）
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# 数据库（建议 VPC 内网）
POSTGRES_HOST=your-polardb-private-host
POSTGRES_PORT=5432
POSTGRES_DB=lvzhi
POSTGRES_USER=lvzhi_app
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql://lvzhi_app:replace_me@your-polardb-private-host:5432/lvzhi

# Redis（建议 VPC 内网）
REDIS_HOST=your-redis-private-host
REDIS_PORT=6379
REDIS_PASSWORD=replace_me

# AI（示例）
DEFAULT_AI_PROVIDER=minimax
MINIMAX_API_KEY=replace_me
MINIMAX_API_BASE=https://api.minimax.chat/v1

# OSS（示例）
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=replace_me
ALIYUN_OSS_ACCESS_KEY_ID=replace_me
ALIYUN_OSS_ACCESS_KEY_SECRET=replace_me

# JWT
JWT_SECRET=replace_with_32_chars_min_secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# 安全
ALLOWED_ORIGINS=https://www.lvxzhi.com,https://lvxzhi.com
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# 日志
LOG_LEVEL=info
LOG_FORMAT=json
