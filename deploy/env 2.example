# ============================================
# 律植 - 环境变量配置模板
# 复制此文件为 deploy/.env 并填写实际值
# ============================================

# ============================================
# 应用基础配置
# ============================================
NODE_ENV=production
APP_NAME=律植
APP_URL=https://your-domain.cn
API_URL=https://your-domain.cn/api

# ============================================
# 数据库配置
# ============================================
# 方式1: 使用 Docker Compose 自带的 PostgreSQL
POSTGRES_USER=lvzhi
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://lvzhi:your_secure_password_here@postgres:5432/lvzhi

# 方式2: 使用阿里云RDS PostgreSQL（国内推荐）
# POSTGRES_HOST=pgm-xxxxxxxxxxx.pg.rds.aliyuncs.com
# POSTGRES_PORT=5432
# POSTGRES_DB=lvzhi
# POSTGRES_USER=lvzhi
# POSTGRES_PASSWORD=your_secure_password_here
# DATABASE_URL=postgresql://lvzhi:your_secure_password_here@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================
# 前端 API 入口（不再依赖 Supabase）
# ============================================
NEXT_PUBLIC_API_URL=https://your-domain.cn/api

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# 阿里云 Redis（国内推荐）
# REDIS_HOST=redis.aliyuncs.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password_here

# ============================================
# AI 服务配置（国内 LLM）
# ============================================
# 推荐使用以下国内服务商之一：

# ---- 方案1: 智谱 AI (GLM-4) - 推荐 ⭐ ----
AI_PROVIDER=zhipu
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ---- 方案2: 阿里云通义千问 (Qwen) ----
# AI_PROVIDER=dashscope
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ---- 方案3: 百度文心一言 (ERNIE) ----
# AI_PROVIDER=wenxin
# WENXIN_API_KEY=your_wenxin_api_key
# WENXIN_SECRET_KEY=your_wenxin_secret_key

# ---- 方案4: 腾讯混元 (Hunyuan) ----
# AI_PROVIDER=hunyuan
# HUNYUAN_SECRET_ID=your_secret_id
# HUNYUAN_SECRET_KEY=your_secret_key

# ============================================
# 短信服务（用于验证码）
# ============================================
# 阿里云短信（国内推荐）
ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=律植
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

# ============================================
# 对象存储（用于上传文件）
# ============================================
# 阿里云 OSS（国内推荐）⭐
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=lvzhi-assets
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret

# ============================================
# 支付配置
# ============================================
# 支付宝（需要企业资质）
ALIPAY_APP_ID=your_app_id
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key

# 微信支付（需要企业资质）
WECHAT_PAY_MCH_ID=your_mch_id
WECHAT_PAY_API_KEY=your_api_key
WECHAT_PAY_CERT_PATH=/app/cert/wechat_apiclient_cert.pem
WECHAT_PAY_KEY_PATH=/app/cert/wechat_apiclient_key.pem

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_super_secure_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ============================================
# 第三方服务
# ============================================
# 百度统计（国内分析工具）
BAIDU_TONGJI_ID=your_baidu_tongji_id

# 微信分享 SDK
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ============================================
# 安全配置
# ============================================
ALLOWED_ORIGINS=https://your-domain.cn,https://www.your-domain.cn
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
