# Railway 环境变量配置说明 — web service

# Supabase（可选 · 逐步下线；目标为 PolarDB + 自建 API，不再依赖 Supabase 运行时）
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API 服务地址（浏览器直连跨域场景；与 Next 同源代理二选一配置即可）
NEXT_PUBLIC_API_URL=https://your-api-service.railway.app

# Next 服务端转发 /api/* 到 Fastify（本地默认 http://127.0.0.1:4000，生产填内网或上游地址）
API_PROXY_TARGET=http://127.0.0.1:4000

# 服务端 getSession（RSC）直连 Fastify 的 /api/auth/me；本变量仍用于上游 Origin 等（见 upstream-api-base）
INTERNAL_APP_URL=http://127.0.0.1:3000
