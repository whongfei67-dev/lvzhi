# Railway 环境变量配置说明 — api service

# 端口（Railway 自动注入，无需手动设置）
PORT=4000

# 前端 URL（用于 CORS，填 web service 的 Railway 域名）
WEB_URL=https://your-web-service.railway.app

# Cookie Secure：本地 http 调试可设 COOKIE_SECURE=false；https 生产可设 true 或依赖 WEB_URL 为 https:// 自动开启
# COOKIE_SECURE=false

# ─── Supabase（可选 · 仅迁移或兼容旧脚本时使用）────────────────────
# PolarDB-only 部署：可不配置以下两项，API 仍可启动。
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# （或 Docker 中常用名） SUPABASE_SERVICE_KEY=

# JWT Secret（与 Supabase 的 JWT secret 保持一致）
# Supabase Dashboard → Settings → API → JWT Secret
JWT_SECRET=your_jwt_secret_here

# ─── PostgreSQL（PolarDB / 自建 PG）二选一配置 ─────────────────
# 推荐：单条连接串（内测/生产请用密钥托管注入，勿提交真实值）
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# 或使用分项（未设置 DATABASE_URL 时必填；禁止依赖代码内默认主机/账号）
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_NAME=
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_SSL=true
